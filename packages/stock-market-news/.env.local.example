# Environment variables for stock-market-news agent

# Alibaba Cloud Model Studio API key
# Get from: https://modelstudio.console.alibabacloud.com/ap-southeast-1
DASHSCOPE_API_KEY=

# x402 payment network (defaults to Base Sepolia testnet)
# Options: eip155:84532 (Base Sepolia) | eip155:8453 (Base mainnet)
X402_NETWORK=eip155:84532
